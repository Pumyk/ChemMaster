{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile photo URL" },
        "department": { "type": "string", "description": "The user's department" },
        "phone": { "type": "string", "description": "The user's phone number" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "QuizResult": {
      "title": "Quiz Result",
      "description": "A record of a completed quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who took the quiz" },
        "topicId": { "type": "string", "description": "The ID of the topic" },
        "topicTitle": { "type": "string", "description": "The title of the topic" },
        "score": { "type": "number", "description": "The number of correct answers" },
        "total": { "type": "number", "description": "The total number of questions" },
        "answers": { "type": "array", "description": "The user's answers" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the quiz was completed" }
      },
      "required": ["userId", "topicId", "topicTitle", "score", "total", "answers", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/quiz_results/{resultId}": {
      "schema": "QuizResult",
      "description": "Quiz result documents"
    }
  }
}
